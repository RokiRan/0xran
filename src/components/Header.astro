---
import { useTranslations, localePath, langSwitchHref } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import { profile } from '../data/profile';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
  activePath: string; // '/', '/projects', '/blog', '/now'
}

const { lang, activePath } = Astro.props;
const t = useTranslations(lang);
const p = profile[lang];
const other: Lang = lang === 'en' ? 'zh' : 'en';
const switchHref = langSwitchHref(Astro.url.pathname, other);

const nav = [
  { href: localePath(lang, '/'), label: t('nav.home'), key: '/' },
  { href: localePath(lang, '/projects'), label: t('nav.projects'), key: '/projects' },
  { href: localePath(lang, '/blog'), label: t('nav.blog'), key: '/blog' },
  { href: localePath(lang, '/now'), label: t('nav.now'), key: '/now' },
  { href: localePath(lang, '/links'), label: t('nav.friends'), key: '/links' },
];
---

<header class="site-header" data-header>
  <div class="container">
    <a href={localePath(lang, '/')} class="brand">
      <span class="brand-mark">[R]</span>
      <span>{p.name}</span>
    </a>
    <nav class="nav" aria-label="Primary">
      {
        nav.map((n) => (
          <a href={n.href} {...(activePath === n.key ? { 'aria-current': 'page' } : {})}>
            {n.label}
          </a>
        ))
      }
    </nav>
    <div class="header-tools">
      <a href={switchHref} class="lang-switch" aria-label={t('lang.switch')}>
        <span class={lang === 'en' ? 'active' : ''}>EN</span><span class="sep">/</span><span
          class={lang === 'zh' ? 'active' : ''}>ZH</span
        >
      </a>
      <button
        type="button"
        class="icon-btn"
        data-theme-toggle
        aria-label={t('theme.toDark')}
        data-label-dark={t('theme.toDark')}
        data-label-light={t('theme.toLight')}
      >
        <Icon name="moon" size={18} class="theme-icon theme-icon--moon" />
        <Icon name="sun" size={18} class="theme-icon theme-icon--sun" />
      </button>
      <button type="button" class="icon-btn menu-toggle" aria-label="Menu" data-menu-toggle>
        <Icon name="menu" size={20} />
      </button>
    </div>
  </div>
</header>

<style is:global>
  /* Theme toggle — sunrise/moonset swap animation.
     The two icons stack inside the fixed 36×36 button and swap via
     opacity + transform (display:none can't transition). CSS takes the
     transition timing from the state an element moves INTO, so the
     outgoing icon sets below the horizon quickly while the incoming one
     springs up after a beat. Selectors must be global: the svgs are
     rendered by the Icon component and don't carry this file's scope
     attribute (the old scoped display:none rules never matched). */
  [data-theme-toggle] {
    position: relative;
  }
  .theme-icon {
    position: absolute;
    inset: 0;
    margin: auto;
  }

  /* Visible state — springy entrance (applies when an icon becomes visible) */
  .theme-icon--moon,
  :root[data-theme='dark'] .theme-icon--sun {
    transform: none;
    opacity: 1;
    transition:
      transform 420ms var(--ease-out-back) 70ms,
      opacity 240ms var(--ease-out-quart) 70ms;
  }

  /* Hidden state — sunk below the horizon, quick exit */
  .theme-icon--sun,
  :root[data-theme='dark'] .theme-icon--moon {
    transform: translateY(10px) rotate(-120deg) scale(0.25);
    opacity: 0;
    transition:
      transform 220ms var(--ease-in-out-quart),
      opacity 160ms var(--ease-in-out-quart);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-icon {
      transform: none !important;
      transition: opacity 150ms linear !important;
    }
  }
</style>
