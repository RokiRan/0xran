---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  activePath?: '/' | '/projects' | '/blog' | '/now';
}

const { lang, title, description, activePath = '/' } = Astro.props;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={t('meta.author')} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={t('rss.title')}
      href={`/${lang}/rss.xml`}
    />

    <!-- Theme init — must run before paint to avoid FOUC -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('camp-theme');
          var theme =
            stored ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch (e) {}
      })();
    </script>

    <ClientRouter />
    <Analytics />
  </head>
  <body>
    <Header lang={lang} activePath={activePath} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      import '../scripts/app';
    </script>
  </body>
</html>
