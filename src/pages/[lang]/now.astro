---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { useTranslations, localePath, formatDate } from '../../i18n/utils';
import { languages, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

/** Bump this date whenever the lists below change. */
const NOW_UPDATED = new Date('2026-07-23');

interface NowItem {
  date: string;
  title: string;
  body: string; // may contain inline <code>
}

const nowContent: Record<Lang, { watching: NowItem[]; avoiding: NowItem[] }> = {
  zh: {
    watching: [
      {
        date: '2026-07',
        title: 'OneShell',
        body: '维护期。最近在打磨终端里的 AI 助手，让它能直接解释当前会话里的报错。',
      },
      {
        date: '2026-07',
        title: 'MyNavicat',
        body: '路线图上的下几项：PostgreSQL 支持、单元格编辑、SSH 隧道。',
      },
      {
        date: '2026-07',
        title: '本职工作',
        body: '在制造业做信息化。把数据、流程、自动化这套东西搬进车间，先从少打印几张纸开始。',
      },
    ],
    avoiding: [
      {
        date: '2026-07',
        title: '新开坑',
        body: '两个项目都在维护期，先把它们做扎实。',
      },
      {
        date: '2026-07',
        title: '给这个站加功能',
        body: '能写字、能放项目就够了。',
      },
    ],
  },
  en: {
    watching: [
      {
        date: '2026-07',
        title: 'OneShell',
        body: 'Maintenance mode. Currently polishing the AI assistant in the terminal so it can explain errors from the live session.',
      },
      {
        date: '2026-07',
        title: 'MyNavicat',
        body: 'Next on the roadmap: PostgreSQL support, cell editing, and SSH tunneling.',
      },
      {
        date: '2026-07',
        title: 'Day job',
        body: 'Informatization work in manufacturing — bringing data, process, and automation into the workshop, starting with printing fewer forms.',
      },
    ],
    avoiding: [
      {
        date: '2026-07',
        title: 'New side projects',
        body: 'Both projects are in maintenance. Make them solid first.',
      },
      {
        date: '2026-07',
        title: 'Adding features to this site',
        body: 'It holds writing and projects. That is enough.',
      },
    ],
  },
};

const { watching, avoiding } = nowContent[lang];
---

<BaseLayout lang={lang} title={`${t('now.title')} · ${t('meta.siteName')}`} description={t('now.lede')} activePath="/now">
  <section class="page-hero">
    <div class="container container--content">
      <div class="fade-up">
        <a href={localePath(lang, '/')} class="back-link">
          <Icon name="arrowLeft" size={14} />
          <span>{t('nav.home')}</span>
        </a>
      </div>
      <span class="eyebrow fade-up" style="--i:1">{t('now.eyebrow', { date: formatDate(NOW_UPDATED, lang) })}</span>
      <h1 class="page-title fade-up" style="--i:2">{t('now.title')}</h1>
      <p class="hero-lede fade-up" style="--i:3; max-width: 56ch;">{t('now.lede')}</p>
      <span class="hero-rule fade-up" style="--i:4" aria-hidden="true"></span>
    </div>
  </section>

  <section class="section">
    <div class="container container--content">
      <h2 class="fade-up" style="margin-bottom: 16px;">{t('now.watching')}</h2>
      <ul class="now-list fade-up" style="--i:1">
        {
          watching.map((item) => (
            <li class="now-item">
              <span class="date tabular">{item.date}</span>
              <div class="body">
                <strong>{item.title}</strong>
                <p set:html={item.body} />
              </div>
            </li>
          ))
        }
      </ul>

      <h2 class="fade-up" style="margin-top: 48px; margin-bottom: 16px;">{t('now.avoiding')}</h2>
      <ul class="now-list fade-up" style="--i:1">
        {
          avoiding.map((item) => (
            <li class="now-item">
              <span class="date tabular">{item.date}</span>
              <div class="body">
                <strong>{item.title}</strong>
                <p set:html={item.body} />
              </div>
            </li>
          ))
        }
      </ul>

      <hr class="divider" style="margin-top: 64px;" />
      <p class="fade-up text-muted" style="margin-top: 32px; font-size: 0.875rem; max-width: 56ch;">
        {t('now.inspiration')}
        <a href="https://nownownow.com/about" class="link" target="_blank" rel="noopener noreferrer">nownownow.com</a>{t('now.inspiration.tail')}
      </p>
    </div>
  </section>
</BaseLayout>
